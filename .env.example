DATABASE_URL="file:./dev.db"

# Twilio - Get these from https://console.twilio.com
TWILIO_ACCOUNT_SID="your_twilio_account_sid"
TWILIO_AUTH_TOKEN="your_twilio_auth_token"
TWILIO_PHONE_NUMBER="your_twilio_phone_number"

# OpenAI - Get this from https://platform.openai.com/api-keys
OPENAI_API_KEY="your_openai_api_key"

# Admin credentials (change this to a random string in production)
ADMIN_JWT_SECRET="change-this-to-a-random-secret-string"

# Notification recipients (use real phone numbers with country code)
PROPERTY_MANAGER_PHONE="+12145551234"
COMPLIANCE_DIRECTOR_PHONE="+12145555678"

# Snap HOA API (placeholder until API access is provided)
SNAP_HOA_API_URL="https://api.snaphoa.com"
SNAP_HOA_API_KEY="placeholder_api_key"

# Production only
NODE_ENV="production"
PORT=3000
